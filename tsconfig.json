{
  "compilerOptions": {
    "baseUrl": ".",
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["*.ts"]
}